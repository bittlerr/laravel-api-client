{
    "name": "macsidigital/laravel-api-client",
    "description": "Laravel API Client Builder package",
    "keywords": [
        "macsidigital",
        "laravel-api-client"
    ],
    "homepage": "https://github.com/macsidigital/laravel-api-client",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Colin Hall",
            "email": "colin@macsi.co.uk"
        }
    ],
    "require": {
        "php": "^8.3 || ^8.4",
        "firebase/php-jwt": "^6.10.2 || ^7.0",
        "guzzlehttp/guzzle": "~7.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "macsidigital/laravel-oauth2-client": "dev-fix-integration-model",
        "nesbot/carbon": "^2.0 || ^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^11.5 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "MacsiDigital\\API\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MacsiDigital\\API\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "test:container": "scripts/test-in-container.sh",
        "test:l11": "scripts/test-in-container.sh 11",
        "test:l12": "scripts/test-in-container.sh 12",
        "test:l13": "scripts/test-in-container.sh 13",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [
        {
            "url": "https://github.com/bittlerr/laravel-oauth2-client.git",
            "type": "git"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "MacsiDigital\\API\\Providers\\APIServiceProvider"
            ],
            "aliases": {}
        }
    }
}
